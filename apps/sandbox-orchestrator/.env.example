PORT=8083
SANDBOX_REQUEST_BODY_LIMIT=50mb
SANDBOX_SLUG_SUFFIX=-sandbox
SANDBOX_SLUG_PREFIX=
SANDBOX_WORKDIR=/root/ai-hub/src
CODEX_APP_SERVER_ENABLED=false
CODEX_HOME=/var/lib/ai-hub/codex
CODEX_APP_SERVER_TURN_TIMEOUT_MS=7200000
CODEX_APP_SERVER_TURN_NO_ACTIVITY_TIMEOUT_MS=180000
CODEX_APP_SERVER_RUST_LOG=codex_core=info,codex_tui=info,codex_app_server=info,codex_api=info,codex_client=info,warn
CODEX_APP_SERVER_ALLOW_TRACE_LOGS=false
CODEX_APP_SERVER_LOG_SQLITE_MAX_BYTES=536870912
CODEX_APP_SERVER_LOG_SQLITE_KEEP_ROTATED=2
SANDBOX_SMTP_HOST=sandbox-mail
SANDBOX_SMTP_PORT=1025
SANDBOX_MAIL_WEB_URL=http://sandbox-mail:8025
SANDBOX_MAIL_API_URL=http://sandbox-mail:8025/api/v1
GEMINI_TOKEN_HOST_DIR=/root/infra/gemini-token
PEPPER_TOKEN_HOST_DIR=/root/infra/pepper-token
LUMA_TOKEN_HOST_DIR=/root/infra/luma-token
KLING_TOKEN_HOST_DIR=/root/infra/kling-token
HEYGEN_TOKEN_HOST_DIR=/root/infra/heygen-token
AWS_CREDENTIALS_HOST_DIR=/root/infra/aws
