PORT=8083
SANDBOX_REQUEST_BODY_LIMIT=50mb
SANDBOX_SLUG_SUFFIX=-sandbox
SANDBOX_SLUG_PREFIX=
SANDBOX_WORKDIR=/root/ai-hub/src
CODEX_APP_SERVER_ENABLED=false
CODEX_HOME=/var/lib/ai-hub/codex
CODEX_APP_SERVER_TURN_TIMEOUT_MS=7200000
SANDBOX_SMTP_HOST=sandbox-mail
SANDBOX_SMTP_PORT=1025
SANDBOX_MAIL_WEB_URL=http://sandbox-mail:8025
SANDBOX_MAIL_API_URL=http://sandbox-mail:8025/api/v1
GEMINI_TOKEN_HOST_DIR=/root/infra/gemini-token
AWS_CREDENTIALS_HOST_DIR=/root/infra/aws
