{$CADDY_DOMAIN} {
    encode zstd gzip

    @api path /api/*
    handle @api {
        reverse_proxy backend:8081
    }

    @sandbox path /sandbox/*
    handle @sandbox {
        reverse_proxy sandbox-orchestrator:8083
    }

    @mcp_health path /mcp
    handle @mcp_health {
        rewrite * /actuator/health
        reverse_proxy mcp-server:8084
    }

    @mcp path /mcp/*
    handle @mcp {
        reverse_proxy mcp-server:8084
    }

    handle {
        reverse_proxy frontend:80
    }
}
